# Port the server listens on. Most hosts (Render, Fly, Railway) set this for you.
PORT=3000

# Redis connection string. Get a free database at https://upstash.com (gives you
# a rediss:// URL with TLS already configured).
REDIS_URL=redis://127.0.0.1:6379

# Random long secret used to sign the anonymous identity cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=change-me-to-a-random-64-char-hex-string

# Bearer token required to call the /admin/* endpoints. Generate the same way as above.
ADMIN_SECRET=change-me-to-a-different-random-secret

# TURN credentials, used so calls still connect when direct peer-to-peer fails
# (symmetric NAT, strict firewalls). Preferred: Cloudflare Realtime TURN
# (https://developers.cloudflare.com/realtime/turn/) — generous free tier
# (1,000 GB/month relayed), short-lived credentials minted server-side by
# lib/cloudflareTurn.js. Create a TURN app in the Cloudflare dashboard to get
# these two values:
CLOUDFLARE_TURN_KEY_ID=your-turn-key-id
CLOUDFLARE_TURN_API_TOKEN=your-turn-key-api-token

# Fallback TURN config, used only if the Cloudflare vars above are unset or
# Cloudflare's API is unreachable. Any static-credential TURN provider works
# here (e.g. https://www.metered.ca). Comma-separate multiple URLs.
TURN_URLS=turn:your-turn-host:80
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential
